# macOS
.DS_Store
.AppleDouble
.LSOverride

# Claude Code — skills and commands tracked, everything else ignored
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/commands/
!.claude/commands/**
.mcp.json
SPRINT.md

# Internal dev docs (not for public repo)
docs/CLOUD-SYNC-DESIGN.md
docs/UI-WIREFRAME.md

# Internal dev scripts
versionbump.py
generate-seed-data.py

# Jules AI agent artifacts — journals (.md) are tracked, scripts/screenshots are not
.jules/*
!.jules/*.md
.Jules/*
!.Jules/*.md
verification/
modify_*.py
verify_*.py

# Node modules (if added in future)
node_modules/
npm-debug.log*

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Environment variables
.env
.env.local

# Python
__pycache__/
*.pyc

# DevOps tooling — all tracked in git; excluded from releases via .gitattributes export-ignore
# Keep secrets and build artifacts out
devops/**/.env
devops/screenshots/
devops/node_modules/

# Playwright test artifacts
test-results/

# AI/MCP configuration files are tracked for project consistency
# (removed: .github/instructions/codacy.instructions.md)
.firecrawl/

devops/mem0/.env

# Version lock — transient runtime file, not project history
devops/version.lock

# Local DevOps hub — machine-specific links and report archive, not tracked
devops/hub/

# Git worktrees for isolated agent work — content dirs are transient, not project history
.claude/worktrees/
# Ignore spec-workflow transient data (specs, logs, approvals) but track user-templates, steering, and templates
.spec-workflow/*
!.spec-workflow/user-templates/
!.spec-workflow/user-templates/**
!.spec-workflow/steering/
!.spec-workflow/steering/**
!.spec-workflow/templates/
!.spec-workflow/templates/**

# Wiki nightwatch — local rotation state, not project history
wiki/.nightwatch-log.json
.playwright-mcp/
